{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "paths": {
      "$lib/*": ["./src/lib/*"],
      "$components/*": ["./src/components/*"],
      "$i18n/*": ["./src/i18n/*"]
    },
    "strictNullChecks": true,
    "allowJs": true
  },
  "include": ["src/**/*", "*.ts"],
  "exclude": ["node_modules"]
}
