---
import Layout from '../layouts/Layout.astro';
import SyncPairing from '../components/SyncPairing.svelte';
import Nav from '../components/Nav.svelte';
---

<Layout title="Vacationes - Sincronizar">
  <main class="pb-20">
    <header class="bg-white shadow-sm sticky top-0 z-10">
      <div class="max-w-md mx-auto px-4 py-4">
        <h1 class="text-2xl font-bold text-gray-900">Sincronização</h1>
        <p class="text-sm text-gray-500">P2P • Sem Servidor</p>
      </div>
    </header>
    
    <div class="max-w-md mx-auto px-4 py-4">
      <SyncPairing client:only="svelte" />
    </div>
    
    <Nav client:only="svelte" currentPage="sync" />
  </main>
</Layout>
